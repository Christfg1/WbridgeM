{
  "Bridge": {
    "Port": 5055,
    "SharedSecret": "change-this-secret",
    "StorageRoot": "%USERPROFILE%\\Documents\\BridgeDrop",
    "StatusBroadcastSeconds": 5,
    "ClipboardPollSeconds": 2,
    "CommandTimeoutSeconds": 90,
    "BlockedCommandTokens": [
      "format ",
      "diskpart",
      "shutdown",
      "restart-computer",
      "stop-computer",
      "remove-item -recurse",
      "del /s",
      "rmdir /s",
      "cipher /w"
    ]
  }
}
